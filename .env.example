# Server image selection
GAIKO2_TEE_IMAGE=gaiko2-tee:latest
GAIKO2_NATIVE_IMAGE=gaiko2-native:latest

# Host ports and bind mounts
GAIKO2_TEE_PORT=8080
GAIKO2_NATIVE_PORT=8080
GAIKO2_CONFIG_DIR_HOST=./var/config
GAIKO2_SECRET_DIR_HOST=./var/secrets

# TEE runtime selection. Use GAIKO2_TEE_TYPE=tdx only for the TDX replay binary.
GAIKO2_TEE_TYPE=ego
GAIKO2_TDXS_SOCKET=/var/tdxs.sock
GAIKO2_FORK=shasta
# Leave empty if you want gaiko2 to resolve the id from registered.gaiko2.json.
GAIKO2_INSTANCE_ID=
GAIKO2_REGISTER_HOOK=

# PCCS endpoint
PCCS_HOST=host.docker.internal:8081
