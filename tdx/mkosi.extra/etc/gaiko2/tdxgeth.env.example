# Copy this file to /etc/gaiko2/tdxgeth.env inside the measured image.
# Do not commit RPC credentials, private keys, or operator-specific values.

CHAIN_ID=
TAIKO_INTERNAL_SHASTA_TIME=
BOOT_NODES=

L1_ENDPOINT_WS=
L1_BEACON_HTTP=
BLOB_SERVER_URL=

TAIKO_INBOX_ADDRESS=
SHASTA_INBOX_ADDRESS=
TAIKO_ANCHOR_ADDRESS=
PRECONFIRMATION_WHITELIST=

VERBOSITY=3
GETH_P2P_PORT=30306
GETH_MAXPEERS=50
GETH_MAXPENDPEERS=0

ENABLE_PRECONFS_P2P=false
DISABLE_P2P_SYNC=true
P2P_SYNC_URL=
P2P_TCP_PORT=4001
P2P_UDP_PORT=30303
P2P_BOOTNODES=
P2P_PRIV_PATH=/persistent/taiko-client/private-key
PUBLIC_IP=

GAIKO2_PORT=8080
GAIKO2_PROVING_MODE=tdxgeth
GAIKO2_TEE_TYPE=tdx
GAIKO2_TDXS_SOCKET=/var/tdxs.sock
GAIKO2_L2_RPC_URL=http://127.0.0.1:8545
GAIKO2_CONFIG_DIR=/persistent/gaiko2/config
GAIKO2_SECRET_DIR=/persistent/gaiko2/secrets
GAIKO2_FORK=shasta
