[Unit]
Description=TDX quote service
After=runtime-init.service network-online.target
Requires=runtime-init.service
Wants=tdxs.socket

[Service]
User=tdxs
Group=tdx
WorkingDirectory=/var/lib/tdxs
Type=notify
ExecStart=/usr/bin/tdxs --config /etc/tdxs/config.yaml
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
